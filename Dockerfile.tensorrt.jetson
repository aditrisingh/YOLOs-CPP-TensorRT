# ============================================================================
# YOLOs-TRT Production Dockerfile — NVIDIA Jetson (JetPack 6.x / L4T)
# ============================================================================
# Build and run on Jetson Orin / Xavier devices.
#
# Build on-device:
#   docker build -f Dockerfile.tensorrt.jetson -t yolos-trt-jetson .
#
# Run:
#   docker run --runtime nvidia -v /path/to/models:/app/models \
#              -v /path/to/data:/app/data yolos-trt-jetson \
#              ./image_inference ./models/yolo11n.trt ./data/dog.jpg
# ============================================================================

# JetPack 6.x base with TensorRT pre-installed
FROM nvcr.io/nvidia/l4t-tensorrt:r36.3.0 AS builder

ENV DEBIAN_FRONTEND=noninteractive

RUN apt-get update && apt-get install -y --no-install-recommends \
    build-essential cmake git pkg-config \
    libopencv-dev \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /build

COPY CMakeLists.txt ./
COPY include/ include/
COPY src/ src/

# Build (Jetson: sm_72 for Xavier, sm_87 for Orin)
RUN mkdir -p build && cd build && \
    cmake .. \
        -DCMAKE_BUILD_TYPE=Release \
        -DCMAKE_CUDA_ARCHITECTURES="72;87" \
    && make -j"$(nproc)"

# ----- Runtime -----
FROM nvcr.io/nvidia/l4t-tensorrt:r36.3.0 AS runtime

ENV DEBIAN_FRONTEND=noninteractive

RUN apt-get update && apt-get install -y --no-install-recommends \
    libopencv-core4.5d libopencv-imgproc4.5d \
    libopencv-highgui4.5d libopencv-imgcodecs4.5d \
    libopencv-videoio4.5d \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

COPY --from=builder /build/build/image_inference .
COPY --from=builder /build/build/video_inference .
COPY --from=builder /build/build/camera_inference .
COPY --from=builder /build/build/class_image_inference .
COPY --from=builder /build/build/batch_image_inference .

COPY models/*.names models/
RUN mkdir -p data

ENTRYPOINT ["/bin/bash", "-c"]
CMD ["echo 'YOLOs-TRT Jetson ready. Run: ./image_inference <engine> <image> [labels]'"]
